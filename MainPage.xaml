<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FitnessApp.Models"
             xmlns:vm="clr-namespace:FitnessApp.ViewModels"
             x:Class="FitnessApp.MainPage"
             x:DataType="vm:MainViewModel"
             Title="Workouts">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">
        
        <!-- Header + actions -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
            <Label Grid.Column="0"
                   Text="Your workouts"
                   FontSize="28"
                   FontAttributes="Bold"
                   VerticalOptions="Center" />

            <Button Grid.Column="1"
                    Text="+ Add"
                    Command="{Binding AddWorkoutCommand}"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    VerticalOptions="Center" />

            <Button Grid.Column="2"
                    Text="🤖 AI Coach"
                    Command="{Binding GenerateAiWorkoutCommand}"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    VerticalOptions="Center" />
        </Grid>

        <!-- Workout list + AI loading overlay -->
        <Grid Grid.Row="1">
            <CollectionView ItemsSource="{Binding Workouts}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedWorkout, Mode=TwoWay}"
                            SelectionChanged="OnWorkoutSelectionChanged">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                        <Label
                            Text="No workouts yet"
                            HorizontalTextAlignment="Center"
                            FontSize="20"
                            FontAttributes="Bold" />
                        <Label
                            Text="Saved workouts will appear here."
                            HorizontalTextAlignment="Center"
                            Opacity="0.7" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Workout">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems Mode="Execute">
                                    <SwipeItemView Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=DeleteWorkoutCommand}"
                                                   CommandParameter="{Binding .}">
                                        <Border WidthRequest="100"
                                                BackgroundColor="#DC3545"
                                                StrokeShape="RoundRectangle 8"
                                                Margin="0,0,0,8">
                                            <Label Text="Delete"
                                                   TextColor="White"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   FontAttributes="Bold" />
                                        </Border>
                                    </SwipeItemView>
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border StrokeShape="RoundRectangle 10" Padding="12" Margin="0,0,0,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=WorkoutTappedCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" />
                                    <Label Text="{Binding Date, StringFormat='{0:g}'}" FontSize="14" Opacity="0.75" />
                                </VerticalStackLayout>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ActivityIndicator IsRunning="{Binding IsAiBusy}"
                               IsVisible="{Binding IsAiBusy}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Scale="1.5"
                               ZIndex="1" />
        </Grid>
    </Grid>

</ContentPage>