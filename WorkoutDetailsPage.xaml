<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FitnessApp.Models"
             xmlns:vm="clr-namespace:FitnessApp.ViewModels"
             xmlns:converters="clr-namespace:FitnessApp.Converters"
             x:Class="FitnessApp.WorkoutDetailsPage"
             x:DataType="vm:WorkoutDetailsViewModel"
             Title="Workout details">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BoolToInverseVisibilityConverter x:Key="BoolToInverseVisibilityConverter" />
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converters:BoolToStrokeThicknessConverter x:Key="BoolToStrokeThicknessConverter" />
            <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Toggle Layout"
                     Command="{Binding ToggleLayoutCommand}"
                     Order="Primary" />
    </ContentPage.ToolbarItems>

    <!-- Основният контейнер -->
    <Grid RowDefinitions="Auto,*,Auto,Auto" Padding="16" RowSpacing="12">

        <!-- 1. Заглавие на тренировката -->
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Label Text="{Binding Workout.Name}"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}" />
            <Label Text="{Binding Workout.Date, StringFormat='{0:g}'}"
                   FontSize="14"
                   Opacity="0.6" />
            
            <!-- Global START WORKOUT button -->
            <Button Text="START WORKOUT"
                    Command="{Binding StartWorkoutCommand}"
                    BackgroundColor="#28A745"
                    TextColor="White"
                    HeightRequest="60"
                    CornerRadius="30"
                    FontAttributes="Bold"
                    FontSize="18"
                    IsVisible="{Binding IsWorkoutNotRunning}"
                    Margin="0,10,0,0" />
            
            <!-- Workout duration display -->
            <Label Text="{Binding TotalWorkoutDuration, StringFormat='Total Time: {0:hh\\:mm\\:ss}'}"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="#28A745"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- 2. Списък с упражнения - List View -->
        <CollectionView x:Name="ListView"
                      Grid.Row="1" 
                      ItemsSource="{Binding Exercises}"
                      IsVisible="{Binding IsListView}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout ItemSpacing="10" Orientation="Vertical" />
            </CollectionView.ItemsLayout>
            
            <CollectionView.EmptyView>
                <Label Text="No exercises yet." HorizontalTextAlignment="Center" VerticalOptions="Center" />
            </CollectionView.EmptyView>
            
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Exercise">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Execute">
                                <SwipeItem Text="Delete"
                                           BackgroundColor="Red"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WorkoutDetailsViewModel}}, Path=DeleteExerciseCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        
                        <Border StrokeShape="RoundRectangle 14" Padding="15" Margin="0,0,0,10" 
                        BackgroundColor="{AppThemeBinding Light=#F0F4F8, Dark=#1E2633}"
                        Stroke="{Binding IsActive, Converter={StaticResource BoolToColorConverter}}"
                        StrokeThickness="{Binding IsActive, Converter={StaticResource BoolToStrokeThicknessConverter}}"
                        Opacity="{Binding IsCompleted, Converter={StaticResource BoolToOpacityConverter}}">
                            <Border.GestureRecognizers>
                                <DropGestureRecognizer Drop="OnDrop" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto, Auto, Auto, *" RowDefinitions="Auto, Auto" ColumnSpacing="15">
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="≡"
                                       FontSize="24"
                                       TextColor="Gray"
                                       VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <DragGestureRecognizer DragStarting="OnDragStarting" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <!-- Sequence Number Badge -->
                                <Border Grid.Row="0" Grid.Column="1" StrokeShape="Ellipse" WidthRequest="32" HeightRequest="32" BackgroundColor="#512BD4" Padding="0">
                                    <Label Text="{Binding SequenceNumber}" 
                                           TextColor="White" 
                                           FontSize="14" 
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="Center" 
                                           VerticalTextAlignment="Center" />
                                </Border>
                                
                                <Label Grid.Row="0" Grid.Column="2" Text="🏋️" FontSize="24" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" WidthRequest="40" HeightRequest="40" />
                                
                                <VerticalStackLayout Grid.Row="0" Grid.Column="3" Spacing="2">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="18" />
                                    <Label>
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding Sets}" />
                                            <Span Text=" sets × " />
                                            <Span Text="{Binding Reps}" />
                                            <Span Text=" reps" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                    <Label Text="{Binding RestTimeInSeconds, StringFormat='Rest: {0}s'}" FontSize="12" TextColor="#28A745" FontAttributes="Bold" />
                                    <Label Text="{Binding ActiveTime, StringFormat='Time: {0:mm\\:ss}'}" FontSize="11" TextColor="#6C757D" />
                                    <!-- Completed exercise indicator -->
                                    <HorizontalStackLayout IsVisible="{Binding IsCompleted}" Spacing="5">
                                        <Label Text="✓" TextColor="#28A745" FontSize="16" FontAttributes="Bold" />
                                        <Label Text="Completed" TextColor="#28A745" FontSize="12" FontAttributes="Bold" />
                                    </HorizontalStackLayout>
                                    <Button Text="FINISH SET" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WorkoutDetailsViewModel}}, Path=FinishSetCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#DC3545"
                                            TextColor="White"
                                            HeightRequest="32"
                                            CornerRadius="16"
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            IsVisible="{Binding IsActive}" />
                                </VerticalStackLayout>

                                <Border Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="4"
                                        StrokeShape="RoundRectangle 8"
                                        BackgroundColor="{AppThemeBinding Light=#E9ECEF, Dark=#2A2A3E}"
                                        Stroke="Transparent"
                                        Padding="12,8"
                                        Margin="0,12,0,0">
                                    <Editor Text="{Binding Notes}"
                                            Placeholder="Add exercise notes..."
                                            FontSize="13"
                                            TextColor="{AppThemeBinding Light=#495057, Dark=#CED4DA}"
                                            PlaceholderColor="Gray"
                                            AutoSize="TextChanges"
                                            BackgroundColor="Transparent"
                                            Unfocused="OnExerciseNotesUnfocused" />
                                </Border>
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- 2. Списък с упражнения - Grid View -->
        <CollectionView x:Name="GridView"
                      Grid.Row="1" 
                      ItemsSource="{Binding Exercises}"
                      IsVisible="{Binding IsGridView}">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="10" HorizontalItemSpacing="10" />
            </CollectionView.ItemsLayout>
            
            <CollectionView.EmptyView>
                <Label Text="No exercises yet." HorizontalTextAlignment="Center" VerticalOptions="Center" />
            </CollectionView.EmptyView>
            
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Exercise">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Execute">
                                <SwipeItem Text="Delete"
                                           BackgroundColor="Red"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WorkoutDetailsViewModel}}, Path=DeleteExerciseCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        
                        <Border StrokeShape="RoundRectangle 12" Padding="12" Margin="0" 
                        BackgroundColor="{AppThemeBinding Light=#F0F4F8, Dark=#1E2633}"
                        Stroke="{Binding IsActive, Converter={StaticResource BoolToColorConverter}}"
                        StrokeThickness="{Binding IsActive, Converter={StaticResource BoolToStrokeThicknessConverter}}"
                        Opacity="{Binding IsCompleted, Converter={StaticResource BoolToOpacityConverter}}">
                            <Border.GestureRecognizers>
                                <DropGestureRecognizer Drop="OnDrop" />
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="Auto, Auto, *" RowSpacing="8">
                                <!-- Sequence Number Badge -->
                                <Border Grid.Row="0" StrokeShape="Ellipse" WidthRequest="28" HeightRequest="28" BackgroundColor="#512BD4" Padding="0" HorizontalOptions="Center">
                                    <Label Text="{Binding SequenceNumber}" 
                                           TextColor="White" 
                                           FontSize="12" 
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="Center" 
                                           VerticalTextAlignment="Center" />
                                </Border>
                                
                                <Label Grid.Row="1" Text="🏋️" FontSize="24" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                
                                <VerticalStackLayout Grid.Row="2" Spacing="4">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="12" HorizontalTextAlignment="Center" />
                                    <Label>
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding Sets}" />
                                                <Span Text=" × " />
                                                <Span Text="{Binding Reps}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                    <Label Text="{Binding RestTimeInSeconds, StringFormat='Rest: {0}s'}" FontSize="10" TextColor="#28A745" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding ActiveTime, StringFormat='Time: {0:mm\\:ss}'}" FontSize="9" TextColor="#6C757D" HorizontalTextAlignment="Center" />
                                    <Editor Text="{Binding Notes}"
                                            Placeholder="Add exercise notes..."
                                            FontSize="11"
                                            TextColor="Gray"
                                            AutoSize="TextChanges"
                                            BackgroundColor="Transparent"
                                            Unfocused="OnExerciseNotesUnfocused" />
                                    <!-- Completed exercise indicator -->
                                    <HorizontalStackLayout IsVisible="{Binding IsCompleted}" Spacing="3" HorizontalOptions="Center">
                                        <Label Text="✓" TextColor="#28A745" FontSize="12" FontAttributes="Bold" />
                                        <Label Text="Done" TextColor="#28A745" FontSize="8" FontAttributes="Bold" />
                                    </HorizontalStackLayout>
                                    <Button Text="FINISH" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WorkoutDetailsViewModel}}, Path=FinishSetCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#DC3545"
                                            TextColor="White"
                                            HeightRequest="24"
                                            CornerRadius="12"
                                            FontSize="9"
                                            FontAttributes="Bold"
                                            IsVisible="{Binding IsActive}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- 4. Бутони за добавяне (най-отдолу) -->
        <VerticalStackLayout Grid.Row="2" Spacing="10" Margin="0,10,0,0">
            <Button Text="+ Add Exercise"
                    Command="{Binding AddExerciseCommand}"
                    HeightRequest="55"
                    CornerRadius="27"
                    FontAttributes="Bold" />
            <Button Text="Undo Delete"
                    Command="{Binding UndoCommand}"
                    BackgroundColor="#28A745"
                    TextColor="White"
                    HeightRequest="45"
                    CornerRadius="22"
                    FontAttributes="Bold"
                    IsVisible="{Binding HasDeletedExercises}" />
        </VerticalStackLayout>

        <Grid Grid.Row="0" Grid.RowSpan="4"
              IsVisible="{Binding IsResting}"
              BackgroundColor="#AA000000" 
              ZIndex="1000">
            
            <Border StrokeShape="RoundRectangle 30" 
                    BackgroundColor="#1E1E2E" 
                    StrokeThickness="2"
                    Stroke="#512BD4"
                    Margin="40"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                <VerticalStackLayout Spacing="25" Padding="40,30">
                    
                    <!-- Progress Ring -->
                    <Frame BorderColor="#512BD4" 
                           BackgroundColor="Transparent"
                           CornerRadius="65"
                           WidthRequest="130"
                           HeightRequest="130"
                           Padding="0"
                           HorizontalOptions="Center">
                        <Grid>
                            <Ellipse Fill="#2A2A3E" 
                                     WidthRequest="120" 
                                     HeightRequest="120" 
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center" />
                            <Label Text="{Binding RestSeconds}" 
                                   FontSize="48" 
                                   TextColor="White" 
                                   HorizontalTextAlignment="Center" 
                                   VerticalTextAlignment="Center"
                                   FontAttributes="Bold" />
                        </Grid>
                    </Frame>
                    
                    <Label Text="REST TIME" 
                           FontSize="18" 
                           TextColor="#A0A0B0" 
                           HorizontalTextAlignment="Center" 
                           FontAttributes="Bold" />
                    
                    <HorizontalStackLayout Spacing="15">
                        <Button Text="SKIP REST" 
                                Command="{Binding SkipRestCommand}"
                                BackgroundColor="#512BD4"
                                TextColor="White"
                                HeightRequest="50"
                                WidthRequest="200"
                                CornerRadius="25"
                                FontAttributes="Bold"
                                FontSize="16">
                            <Button.Shadow>
                                <Shadow Brush="#512BD4" 
                                        Offset="0,4" 
                                        Radius="8" 
                                        Opacity="0.3" />
                            </Button.Shadow>
                        </Button>
                    </HorizontalStackLayout>
                    
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Floating Action Button for Undo -->
        <Button Grid.Row="0" Grid.RowSpan="4"
                Text="↶"
                Command="{Binding UndoCommand}"
                BackgroundColor="#28A745"
                TextColor="White"
                WidthRequest="56"
                HeightRequest="56"
                CornerRadius="28"
                FontSize="24"
                FontAttributes="Bold"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="20"
                IsVisible="{Binding HasDeletedExercises}">
            <Button.Shadow>
                <Shadow Brush="#28A745"
                        Offset="0,4"
                        Radius="8"
                        Opacity="0.4" />
            </Button.Shadow>
        </Button>

    </Grid>
</ContentPage>